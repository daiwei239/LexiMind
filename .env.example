EMBEDDING_BACKEND=sentence_transformers
SENTENCE_TRANSFORMER_MODEL=E:/projects/cvprojects/LexRAG/models/bge-base-zh-v1.5
SENTENCE_TRANSFORMER_LOCAL_FILES_ONLY=true
SENTENCE_TRANSFORMER_BATCH_SIZE=64
INDEX_BATCH_SIZE=500
NORMATIVE_CACHE_MIN_LINES=870000

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING_ENABLED=false
TAVILY_API_KEY=

VECTOR_BACKEND=milvus
MILVUS_URI=http://127.0.0.1:19530
MILVUS_TOKEN=
MILVUS_DATABASE=default
# 法条知识库 collection（与 Elasticsearch 索引名一致；勿用 session_attachments）
MILVUS_COLLECTION=civil_code
MILVUS_DIMENSION=768
MILVUS_INDEX_TYPE=HNSW
MILVUS_METRIC_TYPE=COSINE

TOP_K=2
RECALL_TOP_K=3
RERANK_TOP_K=6
RRF_K=60
EVIDENCE_BUDGET=2

ELASTICSEARCH_URL=http://127.0.0.1:9200
ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_USER=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_VERIFY_CERTS=false
ELASTICSEARCH_REQUEST_TIMEOUT=30
SPARSE_RETRIEVAL_BACKEND=elasticsearch

RERANKER_BACKEND=cross_encoder
RERANKER_MODEL=E:/projects/cvprojects/LexRAG/models/bge-reranker-base
RERANKER_LOCAL_FILES_ONLY=true
RERANKER_MAX_LENGTH=512
RERANKER_BATCH_SIZE=16
HYDE_ENABLED=true
HYDE_MAX_CHARS=512

CHUNK_MAX_CHARS=800
CHUNK_LONG_ARTICLE_THRESHOLD=600
